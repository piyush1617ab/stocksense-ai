# StockSense AI — Environment Variables
# Copy this file to `.env.local` and fill in real values for your backend.

# Base URL of your backend API (no trailing slash).
VITE_API_URL=http://localhost:8000

# When "true", the frontend uses local dummy data (data/dummyData.ts) instead of
# hitting VITE_API_URL. Set to "false" once your backend is wired up.
VITE_USE_MOCKS=true

# Optional: storage key for the auth token issued by your backend.
VITE_AUTH_TOKEN_KEY=stocksense_token
